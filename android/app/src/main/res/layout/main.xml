<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:fitsSystemWindows="true">

    <!-- Row 1: camera + stream + USB buttons -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/buttonSwitchCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Switch Cam" />

        <Button
            android:id="@+id/buttonStream"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stream" />

        <Button
            android:id="@+id/buttonUsb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USB" />

        <!-- Live ESP32 connection status — updates every 2 seconds -->
        <TextView
            android:id="@+id/textStatusUsb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:paddingLeft="12dp"
            android:text="ESP32: Not connected"
            android:textColor="#CC0000"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Row 2: task / model / cpu-gpu spinners -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <Spinner
            android:id="@+id/spinnerTask"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawSelectorOnTop="true"
            android:entries="@array/task_array" />

        <Spinner
            android:id="@+id/spinnerModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawSelectorOnTop="true"
            android:entries="@array/model_array" />

        <Spinner
            android:id="@+id/spinnerCPUGPU"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawSelectorOnTop="true"
            android:entries="@array/cpugpu_array" />

    </LinearLayout>

    <!-- Camera preview fills remaining space -->
    <SurfaceView
        android:id="@+id/cameraview"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

</LinearLayout>
